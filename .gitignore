# Ignore the contents of the _site directory and other cache directories
_site/
.sass-cache/

# Ignore the directory for local files during development
local/

# Ignore the Gemfile that is generated
Gemfile.lock

# Ignore files created by npm
node_modules
package-lock.json

# Ignore the vendor file and bundle for alternative installation
vendor/
.bundle/

# Ignore LaTeX build artifacts while keeping generated site PDFs tracked
cv-latex/**/*.aux
cv-latex/**/*.fdb_latexmk
cv-latex/**/*.fls
cv-latex/**/*.log
cv-latex/**/*.out
cv-latex/**/*.pdf
cv-latex/**/*.synctex.gz
cv-latex/**/*.xdv
